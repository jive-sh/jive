{
  "name": "@jive-it/jive",
  "module": "src/index.ts",
  "type": "module",
  "description": "The Jive CLI",
  "license": "MIT",
  "version": "0.0.1",
  "bin": {
    "jive": "bin/jive"
  },
  "scripts": {
    "prebuild": "tsc -p tsconfig.json",
    "build": "bun build ./src/index.ts --compile --outfile ./bin/jive",
    "prepublish": "bun run build && npm version patch --no-git-tag-version",
    "publish": "bun publish ./"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "20.x",
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/cli": "^0.72.0",
    "@effect/platform": "^0.92.1",
    "@effect/platform-node": "^0.98.3",
    "bun": "^1.3.0",
    "effect": "^3.18.4"
  },
  "workspaces": [
    "./effect/packages/*",
    "./"
  ]
}
